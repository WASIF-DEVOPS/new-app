    <mxCell id="e_github_jenkins" value="pollSCM H/5 * * * *" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#24292E;strokeWidth=2;fontSize=9;" edge="1" source="github_icon" target="jenkins_master_icon" parent="1">
