pipeline {
  agent any
  
  environment {
    IMAGE_TAG          = "${env.GIT_COMMIT[0..6]}"
    ECR_REGISTRY       = "175200623112.dkr.ecr.us-east-1.amazonaws.com"
    AWS_DEFAULT_REGION = "us-east-1"
  }
  
  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }
    
    stage('Update Deployments') {
      steps {
        sh '''
          # Update web deployment with new image tag
          kubectl set image deployment/web web=${ECR_REGISTRY}/three-tier-web:${IMAGE_TAG} -n app
          
          # Update app deployment with new image tag  
          kubectl set image deployment/app app=${ECR_REGISTRY}/three-tier-app:${IMAGE_TAG} -n app
          
          # Wait for rollout
          kubectl rollout status deployment/web -n app --timeout=120s
          kubectl rollout status deployment/app -n app --timeout=120s
        '''
      }
    }
    
    stage('Verify') {
      steps {
        sh '''
          kubectl get pods -n app
          kubectl get ingress -n app
        '''
      }
    }
  }
  
  post {
    success {
      echo "Deployment succeeded — Image tag: ${IMAGE_TAG}"
    }
    failure {
      echo "Deployment FAILED — Tag: ${IMAGE_TAG}"
    }
  }
}
