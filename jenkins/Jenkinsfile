pipeline {
  agent {
    kubernetes {
      yaml """
        apiVersion: v1
        kind: Pod
        spec:
          serviceAccountName: jenkins
          nodeSelector:
            role: jenkins-agent
          containers:
          - name: agent
            image: 447777058729.dkr.ecr.us-east-1.amazonaws.com/jenkins-agent:latest
            command: ['cat']
            tty: true
            env:
            - name: DOCKER_HOST
              value: tcp://localhost:2375
            - name: AWS_ACCESS_KEY_ID
              valueFrom:
                secretKeyRef:
                  name: aws-credentials
                  key: AWS_ACCESS_KEY_ID
            - name: AWS_SECRET_ACCESS_KEY
              valueFrom:
                secretKeyRef:
                  name: aws-credentials
                  key: AWS_SECRET_ACCESS_KEY
          - name: dind
            image: docker:24-dind
            securityContext:
              privileged: true
            env:
            - name: DOCKER_TLS_CERTDIR
              value: ""
      """
    }
  }
  environment {
    IMAGE_TAG          = "${env.GIT_COMMIT[0..6]}"
    ECR_REGISTRY       = "447777058729.dkr.ecr.us-east-1.amazonaws.com"
    AWS_DEFAULT_REGION = "us-east-1"
  }
  triggers {
    pollSCM('H/5 * * * *')
  }
  stages {
    stage('Build') {
      steps {
        container('agent') {
          sh '''
            sleep 10
            docker build -t $ECR_REGISTRY/three-tier-web:$IMAGE_TAG -f WebLayer/Dockerfile WebLayer/
            docker build -t $ECR_REGISTRY/three-tier-app:$IMAGE_TAG -f ApplicationLayer/Dockerfile ApplicationLayer/
          '''
        }
      }
    }
    stage('Test') {
      steps {
        container('agent') {
          sh '''
            docker run --rm $ECR_REGISTRY/three-tier-app:$IMAGE_TAG python -m pytest tests/ || true
            docker run --rm $ECR_REGISTRY/three-tier-web:$IMAGE_TAG python -m pytest tests/ || true
          '''
        }
      }
    }
    stage('Push') {
      steps {
        container('agent') {
          sh '''
            aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin $ECR_REGISTRY
            docker push $ECR_REGISTRY/three-tier-web:$IMAGE_TAG
            docker push $ECR_REGISTRY/three-tier-app:$IMAGE_TAG
          '''
        }
      }
    }
    stage('Deploy') {
      steps {
        container('agent') {
          sh '''
            aws eks update-kubeconfig --region us-east-1 --name dev-eks-cluster
            sed "s|IMAGE_TAG_PLACEHOLDER|$IMAGE_TAG|g" k8s/app/three-tier-web-app/k8s/app-deployment.yaml | kubectl apply -f -
            sed "s|IMAGE_TAG_PLACEHOLDER|$IMAGE_TAG|g" k8s/app/three-tier-web-app/k8s/web-deployment.yaml | kubectl apply -f -
            kubectl apply -f k8s/app/three-tier-web-app/k8s/mysql-deployment.yaml
            kubectl apply -f k8s/ingress/ingress.yaml
          '''
        }
      }
    }
  }
  post {
    success {
      echo "Pipeline succeeded — Image tag: ${IMAGE_TAG}"
    }
    failure {
      echo "Pipeline FAILED — Branch: ${env.BRANCH_NAME}, Tag: ${IMAGE_TAG}"
    }
    always {
      cleanWs()
    }
  }
}
